{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "olle",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "olle": "./src/cli/index.ts"
  },
  "scripts": {
    "olle": "bun run ./src/cli/index.ts",
    "daemon": "bun run ./src/daemon/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test test --parallel",
    "test:ci": "bun test test --parallel --reporter=junit --reporter-outfile=.artifacts/junit.xml",
    "db:generate": "drizzle-kit generate",
    "build": "bash scripts/build.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.38.0",
    "drizzle-orm": "^0.45.2",
    "marked": "^18.0.2",
    "openai": "^6.38.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "esbuild": "^0.25.12"
  }
}

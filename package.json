{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "olle",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "olle": "./src/cli/index.ts"
  },
  "scripts": {
    "olle": "bun run ./src/cli/index.ts",
    "daemon": "bun run ./src/daemon/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test test --parallel",
    "test:ci": "bun test test --parallel --reporter=junit --reporter-outfile=.artifacts/junit.xml",
    "db:generate": "drizzle-kit generate",
    "build": "bash scripts/build.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@inkjs/ui": "^2.0.0",
    "ai": "^6.0.188",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.2",
    "ink": "^7.0.3",
    "ink-spinner": "^5.0.0",
    "marked": "^18.0.2",
    "react": "^19.2.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.15",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "esbuild": "^0.25.12"
  }
}

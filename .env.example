# OLL-E — copy to .env and fill in; .env is gitignored.

# --- Core ---------------------------------------------------------------

# Data directory for this daemon. Defaults to ~/.olle when unset.
# Use a scratch path like /tmp/olle-dev for hack-and-reset workflows.
# OLLE_HOME=/tmp/olle-dev

# Hostname reported on the host row; falls back to "localhost".
# HOSTNAME=my-laptop

# --- Chat agent ---------------------------------------------------------

# Required for `olle chat`. Without it the daemon boots but the chat
# agent is disabled (you'll still get event/extension ops).
ANTHROPIC_API_KEY=

# --- Starter extensions -------------------------------------------------
#
# Any name listed in a starter's manifest.secrets[] is resolved in this
# order: ~/.olle/secrets/<NAME> file  →  environment variable.

# discord starter
DISCORD_TOKEN=

# github starter
GH_TOKEN=
